# Port the backend listens on (defaults to 3001 if unset)
PORT=3001

# Allowed CORS origin (the frontend). Defaults to the Vite dev server URL.
CORS_ORIGIN=http://localhost:5173

# Supabase project (hosted Postgres + Auth)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Anthropic API key — used from seminar 6 onward (natural-language logging)
ANTHROPIC_API_KEY=
