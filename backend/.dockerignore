# Never copy installed deps or build output — the image builds them itself.
node_modules
dist

# Secrets and local env — must never enter an image layer.
.env
.env.*
!.env.example

# VCS / editor / OS noise
.git
.gitignore
.DS_Store
.vscode
.idea

# Tooling / test / docs not needed at build or runtime
coverage
*.log
CLAUDE.md
.prettierrc.json
.prettierignore
eslint.config.mjs
vitest.config.ts
**/*.test.ts
Dockerfile
.dockerignore
