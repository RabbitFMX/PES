# PES — production environment for docker compose.
# Copy to .env in this directory and fill in real values. .env is gitignored;
# never commit it. Compose reads this file for ${VAR} interpolation and the
# backend service loads it verbatim via env_file.

# --- Backend (runtime) ---

# Port the backend process listens on inside the container (matches the
# published port in docker-compose.yml).
PORT=3001

# Allowed CORS origin — the URL the browser loads the frontend from.
# e.g. https://juras.aibr.cz in production, http://localhost:8080 locally.
CORS_ORIGIN=

# Supabase project (hosted Postgres + Auth).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Postgres connection string — used ONLY by the migrate/seed scripts
# (npm run db:migrate / db:seed), not at request time.
DATABASE_URL=

# Anthropic API key — used from seminar 6 onward (natural-language logging).
ANTHROPIC_API_KEY=

# --- Frontend (build-time) ---
# These are inlined into the static bundle when the frontend image is built.

# Base URL of the backend, including the /api path, as the BROWSER reaches it.
# e.g. https://juras.aibr.cz/api in production, http://localhost:3001/api locally.
VITE_API_BASE_URL=

# Supabase URL + public anon key for the browser Auth client.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
