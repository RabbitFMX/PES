# PES environment configuration.
# Copy to `.env` (gitignored) and fill in the real values before building:
#   cp .env.example .env
#
# The backend reads these at RUNTIME (via env_file). The VITE_* values are
# baked into the frontend bundle at BUILD time (compose passes them as build
# args), so changing them requires `docker compose build frontend` again.

# --- Backend: runtime config ---

# Port the backend listens on (also the published host port). Default 3001.
PORT=3001

# Allowed CORS origin — the URL the frontend is served from.
# Local demo: http://localhost:8080 ; production: https://<surname>.aibr.cz
CORS_ORIGIN=

# Supabase project (hosted Postgres + Auth). Project Settings -> API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Postgres connection string — used ONLY by the migrate/seed scripts.
# Supabase -> Project Settings -> Database (or any Postgres URL locally).
DATABASE_URL=

# Anthropic API key — used from seminar 6 onward (natural-language logging).
ANTHROPIC_API_KEY=

# --- Frontend: build-time config (VITE_*) ---

# Base URL of the backend API, including the /api path.
# Local demo: http://localhost:3001/api ; production: https://<surname>.aibr.cz/api
VITE_API_BASE_URL=

# Supabase URL + public anon key for the browser Auth client.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
