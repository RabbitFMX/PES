# PES environment configuration (REAL values — gitignored, never commit).
# Generated from .env.example. The backend reads these at RUNTIME (env_file);
# the VITE_* values are baked into the frontend bundle at BUILD time.
#
# Values left EMPTY below are external credentials you must obtain yourself
# (Supabase project, Anthropic). The app boots cleanly without them and simply
# disables the feature that needs each one — see the table in the chat.

# --- Backend: runtime config ---

# Port the backend listens on (also the published host port).
PORT=3001

# Allowed CORS origin — where the browser loads the app from. Served over
# HTTPS at the subdomain via Traefik.
CORS_ORIGIN=https://juras.aibr.cz

# Supabase project (hosted Postgres + Auth). Project Settings -> API.
# EXTERNAL — leave empty until you create the Supabase project.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Postgres connection string — used ONLY by the migrate/seed scripts, never at
# runtime. EXTERNAL — from Supabase -> Project Settings -> Database.
DATABASE_URL=

# Anthropic API key — natural-language logging / weekly recap (seminar 6).
# EXTERNAL — leave empty; the AI features stay disabled, the rest works.
ANTHROPIC_API_KEY=

# --- Frontend: build-time config (VITE_*) ---

# Base URL of the backend API (browser -> backend). Traefik routes /api on the
# subdomain to the backend, so this is same-origin under HTTPS.
VITE_API_BASE_URL=https://juras.aibr.cz/api

# Supabase URL + public anon key for the browser Auth client.
# EXTERNAL — leave empty until you create the Supabase project.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
